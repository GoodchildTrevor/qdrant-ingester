# -------------------------------------------------------
# qdrant-ingester — environment variables (example)
# Copy this file to .env and replace placeholders with real values.
# -------------------------------------------------------

# Host port for the app
APP_PORT=8002

# Document-chunker endpoint (service-to-service)
# Example for docker-compose internal network:
DOCUMENT_CHUNKER_URL=http://document-chunker:8001/chunk
# Example for local testing:
# DOCUMENT_CHUNKER_URL=http://localhost:8001/chunk

# Qdrant connection
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Qdrant service API key (required in production)
QDRANT_API_KEY=changeme_qdrant_api_key

# Shared API key required on incoming requests (X-API-Key header)
# IMPORTANT: replace with a strong secret before deploying
API_KEY=changeme_service_api_key

# Base directory allowed for ingest/sync file access
INGEST_ROOT=/data

# Embedding models (fastembed model names)
DENSE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
SPARSE_MODEL_NAME=Qdrant/bm25

# Embedding batch size (how many lemma strings sent to model at once)
BATCH_SIZE=16

# Qdrant upsert batch size
UPSERT_BATCH_SIZE=16

# Qdrant scroll page size (used for sync and orphan cleanup)
SCROLL_LIMIT=1000

# Passed through to document-chunker per request (optional overrides)
CHUNK_SIZE=512
OVERLAP=1

# Maximum allowed file size for ingest (MB)
MAX_FILE_SIZE_MB=50

# Comma-separated allowed collections (validated)
# Example: ALLOWED_COLLECTIONS=documents,my_collection
ALLOWED_COLLECTIONS=documents

# ---- Debug / observability (non-prod only) ---------------------------------

# Set to "true" to include exception details in HTTP error response bodies (not recommended in prod).
# DEBUG_ERRORS=false

# If set, write DEBUG-level logs to this file.
# DEBUG_LOG_FILE=/tmp/qdrant-ingester-debug.log